# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Canonical public site URL (production). Used to (1) force every request to the
# single canonical host so the OAuth PKCE code_verifier cookie is set/read on the
# same origin, and (2) build server-side auth redirect URLs. Set this in
# production (e.g. on Vercel) to your real domain. Leave UNSET locally so dev
# stays on http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://entrytest.taleemkasafar.com
